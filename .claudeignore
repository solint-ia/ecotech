# ==========================================================================
# .claudeignore — arquivos/pastas ignorados pelo Claude Code
# Objetivo: reduzir gasto de tokens evitando ler conteúdo irrelevante.
# ==========================================================================

# --- Dependências ---------------------------------------------------------
node_modules/
**/node_modules/
jspm_packages/
web_modules/
bower_components/
.pnpm-store/

# --- Lockfiles (enormes e sem valor semântico p/ análise) -----------------
package-lock.json
pnpm-lock.yaml
yarn.lock
**/pnpm-lock.yaml
**/package-lock.json

# --- Builds / saídas -------------------------------------------------------
dist/
**/dist/
build/
out/
.next/
**/.next/
**/out/
coverage/
*.lcov
.nyc_output/

# --- Caches ----------------------------------------------------------------
.turbo/
**/.turbo/
.cache/
.eslintcache
.stylelintcache
*.tsbuildinfo
**/*.tsbuildinfo
next-env.d.ts

# --- Prisma gerado ---------------------------------------------------------
**/prisma/generated/
**/@prisma/client/

# --- Uploads / mídia / temporários ----------------------------------------
uploads/
**/uploads/
docker/**/data/
tmp/
temp/

# --- Ambiente / segredos ---------------------------------------------------
.env
.env.*
*.env

# --- Logs ------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Metadados de SO / IDE -------------------------------------------------
.DS_Store
Thumbs.db
.idea/

# --- Binários / arquivos grandes (não legíveis como texto) ----------------
*.png
*.jpg
*.jpeg
*.gif
*.webp
*.ico
*.svg
*.pdf
*.zip
*.tar
*.tar.gz
*.tgz
*.woff
*.woff2
*.ttf
*.eot
*.mp4
*.mp3
*.wav

# --- Git -------------------------------------------------------------------
.git/
