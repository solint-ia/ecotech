datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  SCHOOL_MANAGER
  TEACHER
  STUDENT
}

enum PointType {
  FLORA
  RIO
  FAUNA
  ESPACO_CULTURAL
  AREA_VERDE
  OUTRO
  ARVORE
  PLANTA
  MANGUEZAL
}

enum Difficulty {
  FACIL
  MODERADA
  DIFICIL
}

enum MediaType {
  IMAGE
  VIDEO
}

enum ContentType {
  GUIA
  FAUNA
  FLORA
  CARTILHA
  PROTOCOLO
  ODS
  CURIOSIDADE
  ARTIGO
  VIDEO
}

enum ApprovalStatus {
  PENDENTE
  APROVADO
  REPROVADO
}

enum VerificationType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

model User {
  id              String           @id @default(uuid())
  name            String
  email           String           @unique
  phone           String?
  password        String
  role            Role             @default(STUDENT)
  schoolId        String?
  profileImage    String?
  emailVerified   DateTime?
  status          Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  school          School?          @relation(fields: [schoolId], references: [id])
  followers       SchoolFollower[]
  trailLikes      TrailLike[]
  savedTrails     SavedTrail[]
  feedPosts       FeedPost[]
  feedLikes       FeedLike[]
  feedComments    FeedComment[]
  feedCommentLikes FeedCommentLike[]
  stories         Story[]
  storyComments   StoryComment[]
  libraryContents LibraryContent[]
}

model VerificationToken {
  id        String           @id @default(uuid())
  email     String
  token     String
  expiresAt DateTime
  type      VerificationType
  createdAt DateTime         @default(now())
  
  @@unique([email, token])
}

model School {
  id              String           @id @default(uuid())
  name            String
  state           String?
  city            String
  location        String
  territory       String
  cnpj            String?
  responsibleName String
  cpfManager      String?
  email           String
  phone           String
  description     String
  coverImage      String?
  status          Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  users           User[]
  followers       SchoolFollower[]
  trails          Trail[]
  feedPosts       FeedPost[]
  stories         Story[]
  libraryContents LibraryContent[]
}

model SchoolFollower {
  id        String   @id @default(uuid())
  schoolId  String
  userId    String
  createdAt DateTime @default(now())
  school    School   @relation(fields: [schoolId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([schoolId, userId])
}

model Trail {
  id               String             @id @default(uuid())
  schoolId         String?
  title            String
  slug             String             @unique
  shortDescription String
  fullDescription  String
  state            String?
  city             String
  coverImage       String
  biome            String
  distanceKm       Float
  duration         String
  difficulty       Difficulty         @default(FACIL)
  wikilocUrl       String?
  safetyWarnings   String?
  status           Boolean            @default(false)
  viewsCount       Int                @default(0)
  likesCount       Int                @default(0)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  school           School?            @relation(fields: [schoolId], references: [id])
  photos           TrailPhoto[]
  likes            TrailLike[]
  savedBy          SavedTrail[]
  points           EducationalPoint[]
  biodiversity     BiodiversityItem[]
  feedPosts        FeedPost[]
}

model TrailPhoto {
  id        String   @id @default(uuid())
  trailId   String
  image     String
  createdAt DateTime @default(now())
  trail     Trail    @relation(fields: [trailId], references: [id], onDelete: Cascade)
}

model TrailLike {
  id        String   @id @default(uuid())
  trailId   String
  userId    String
  createdAt DateTime @default(now())
  trail     Trail    @relation(fields: [trailId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@unique([trailId, userId])
}

model SavedTrail {
  id        String   @id @default(uuid())
  trailId   String
  userId    String
  createdAt DateTime @default(now())
  trail     Trail    @relation(fields: [trailId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@unique([trailId, userId])
}

model EducationalPoint {
  id                      String           @id @default(uuid())
  trailId                 String
  title                   String
  slug                    String           @unique
  type                    PointType        @default(OUTRO)
  order                   Int
  shortDescription        String
  fullDescription         String
  curiosities             String?
  environmentalImportance String
  preservationCare        String
  mainImage               String
  offlineSummary          String
  pdfUrl                  String?
  status                  Boolean          @default(false)
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt
  trail                   Trail            @relation(fields: [trailId], references: [id], onDelete: Cascade)
  qrCodes                 QrCode[]
}

model QrCode {
  id                 String           @id @default(uuid())
  educationalPointId String
  qrTextContent      String
  qrImage            String
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  point              EducationalPoint @relation(fields: [educationalPointId], references: [id], onDelete: Cascade)
}

model BiodiversityItem {
  id                      String   @id @default(uuid())
  trailId                 String
  groupType               String
  popularName             String
  scientificName          String?
  description             String
  image                   String
  curiosities             String?
  environmentalImportance String
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  trail                   Trail    @relation(fields: [trailId], references: [id], onDelete: Cascade)
}

model FeedPost {
  id            String        @id @default(uuid())
  userId        String
  schoolId      String?
  trailId       String?
  title         String
  description   String
  mediaType     MediaType     @default(IMAGE)
  status        Boolean       @default(true)
  likesCount    Int           @default(0)
  commentsCount Int           @default(0)
  sharesCount   Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  user          User          @relation(fields: [userId], references: [id])
  school        School?       @relation(fields: [schoolId], references: [id])
  trail         Trail?        @relation(fields: [trailId], references: [id], onDelete: SetNull)
  images        FeedPostImage[]
  likes         FeedLike[]
  comments      FeedComment[]
}

model FeedPostImage {
  id         String   @id @default(uuid())
  url        String
  order      Int
  feedPostId String
  feedPost   FeedPost @relation(fields: [feedPostId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
}

model FeedLike {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())
  post      FeedPost @relation(fields: [postId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([postId, userId])
}

model FeedComment {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  comment   String
  likesCount Int     @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  post      FeedPost @relation(fields: [postId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
  likes     FeedCommentLike[]
}

model FeedCommentLike {
  id        String   @id @default(uuid())
  commentId String
  userId    String
  createdAt DateTime @default(now())
  comment   FeedComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@unique([commentId, userId])
}

model Story {
  id        String    @id @default(uuid())
  userId    String
  schoolId  String?
  mediaType MediaType @default(IMAGE)
  mediaUrl  String
  caption   String?
  location  String?
  expiresAt DateTime
  status    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id])
  school    School?   @relation(fields: [schoolId], references: [id])
  comments  StoryComment[]
}

model StoryComment {
  id        String   @id @default(uuid())
  storyId   String
  userId    String
  comment   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  story     Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
}

model LibraryContent {
  id             String         @id @default(uuid())
  title          String
  description    String
  contentType    ContentType    @default(GUIA)
  coverImage     String
  fileUrl        String?
  videoUrl       String?
  userId         String
  schoolId       String?
  approvalStatus ApprovalStatus @default(PENDENTE)
  publishedAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  user           User           @relation(fields: [userId], references: [id])
  school         School?        @relation(fields: [schoolId], references: [id])
}

model Partner {
  id           String         @id @default(uuid())
  name         String
  category     String
  description  String
  coverImage   String
  address      String
  state        String?
  city         String
  phone        String
  whatsapp     String?
  instagram    String?
  website      String?
  openingHours String
  status       Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  photos       PartnerPhoto[]
}

model PartnerPhoto {
  id        String   @id @default(uuid())
  partnerId String
  image     String
  createdAt DateTime @default(now())
  partner   Partner  @relation(fields: [partnerId], references: [id])
}
