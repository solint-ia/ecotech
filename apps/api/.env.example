# Configuração do PostgreSQL (Local e Produção)
# Em produção (ex: Supabase), pegue as chaves da dashboard do Supabase (Database Settings)
# Geralmente o Supabase fornece uma String de conexão (DATABASE_URL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/ecotech?schema=public"

# Configuração JWT
# Gere um valor forte e ÚNICO por ambiente. NUNCA reutilize este exemplo.
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET="TROQUE-ME-por-um-segredo-forte-e-unico"

# Configuração do Redis (BullMQ / CacheManager)
# Em produção, você precisará criar um Redis (ex: Upstash ou Render Managed Redis)
# Prefira REDIS_URL (usada pelo cache); REDIS_HOST/PORT é o fallback.
REDIS_URL="redis://localhost:6379"
REDIS_HOST="localhost"
REDIS_PORT="6379"

# Configuração Maileroo (E-mails) — pegue a chave no painel da Maileroo
MAILEROO_API_KEY="sua-chave-maileroo-aqui"

# Supabase (Storage) — Project Settings > API
SUPABASE_URL="https://seu-id.supabase.co"
SUPABASE_SECRET_KEY="sua-service-role-key-aqui"

# Segredo do webhook de revalidação do Next (deve bater com o do apps/web)
REVALIDATION_SECRET="troque-me"

# Configuração de CORS / Frontend
PORT="3333"
FRONTEND_URL="http://localhost:3000"

# Usado para compor links de PDFs e QR Codes
NEXT_PUBLIC_APP_URL="http://localhost:3000"
